# 이 파일을 복사해서 .env 로 저장하고 실제 키를 채우세요.
# 실제 키는 절대 이 example 파일에 넣지 마세요 (git에 올라갑니다).

# 사용할 LLM 제공자: gemini (무료, 기본) 또는 openai
LLM_PROVIDER=gemini

# --- Gemini (무료) ---
# 무료 키 발급(카드 불필요): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=여기에_Gemini_키
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI (유료) ---
# 키 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-여기에_본인_키
OPENAI_MODEL=gpt-4o-mini
